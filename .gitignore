## .NET gitignore

# Build outputs
bin/
obj/
out/

# Visual Studio
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# Rider / JetBrains
.idea/

# Test results
TestResults/
*.trx
*.coverage

# NuGet
*.nupkg
*.snupkg
packages/
.nuget/

# Publish profiles
**/Properties/PublishProfiles/

# Secrets — never commit real secrets
appsettings.Production.json
appsettings.Development.json
secrets.json

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/
